# ═══════════════════════════════════════════════════════
# TENKARA INBOX — Environment Variables
# Copy this to .env.local and fill in your values
# ═══════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (powers Kara AI assistant) ──────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Auth ──────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ── Email credentials are stored in Supabase ──────────
# Not in env vars — you add/manage accounts from the app
# Supports: Gmail, Microsoft/Office365, GoDaddy, iCloud, any IMAP
